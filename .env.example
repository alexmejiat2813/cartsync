# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ───────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="postgresql://cartsync:cartsync_dev@localhost:5432/cartsync"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Minimum 32 chars. Generate: openssl rand -base64 32
JWT_SECRET="change-me-minimum-32-chars-required"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── AWS S3 (required in production) ───────────────────────────────────────────
# IAM policy: s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket only
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="cartsync-media"
# Base URL for constructing presigned URLs (no trailing slash)
CDN_BASE_URL="https://cdn.cartsync.app"

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all (dev only).
CORS_ORIGINS="https://app.cartsync.app,http://localhost:5173"
